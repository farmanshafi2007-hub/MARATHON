rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Help Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /test/connection {
      allow read: if true;
    }

    // 1. Users Collection
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      
      // Runs Subcollection
      match /runs/{runId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }
    
    // 2. Activities Collection
    match /activities/{activityId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Allow appending to likeCount via increments
      allow update: if isAuthenticated() 
                    && (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount']));
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // 3. Likes Tracking Collection
    match /likes/{likeId} {
      allow read: if isAuthenticated();
      
      // The compound ID is `activityId_userId`. 
      allow create: if isAuthenticated() 
                    && request.resource.data.userId == request.auth.uid
                    && likeId == request.resource.data.activityId + '_' + request.auth.uid;
                    
      allow delete: if isAuthenticated() 
                    && resource.data.userId == request.auth.uid;
    }
  }
}
